{
  "name": "@uknowledge/knowledge-ingest-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --exclude 'dist/**'",
    "fixtures:parser": "vitest run src/parser-fixtures.test.ts",
    "fixtures:parser:update": "UPDATE_PARSER_FIXTURES=1 vitest run src/parser-fixtures.test.ts",
    "dev": "node --enable-source-maps dist/index.js",
    "start": "node --enable-source-maps dist/index.js"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@uknowledge/knowledge-schema": "0.1.0",
    "defuddle": "^0.18.1",
    "fastify": "^5.2.1",
    "linkedom": "^0.18.0",
    "zod": "^4.1.12"
  }
}
