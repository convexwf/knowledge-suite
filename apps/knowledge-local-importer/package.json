{
  "name": "@uknowledge/knowledge-local-importer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --exclude 'dist/**'",
    "import:calibre": "node --enable-source-maps dist/main.js calibre",
    "import:html": "node --enable-source-maps dist/main.js html",
    "import:urls": "node --enable-source-maps dist/main.js urls"
  },
  "dependencies": {
    "@uknowledge/knowledge-ingest-server": "0.1.0",
    "@uknowledge/knowledge-schema": "0.1.0"
  }
}
